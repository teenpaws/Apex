# Backend environment variables for Apex Platform
# Copy this file to .env and fill in real values when available.
# During development, MOCK_AGENTS=true and USE_MOCK_DATA=true mean no real API calls are made.

# ── Database / Supabase ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/apex
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── AI / LLM ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# ── External Data APIs ────────────────────────────────────────────────────────
PROXYCURL_API_KEY=your-proxycurl-api-key
NEWS_API_KEY=your-newsapi-key
CRUNCHBASE_API_KEY=your-crunchbase-api-key
DEALROOM_API_KEY=your-dealroom-api-key

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# ── Gmail OAuth ───────────────────────────────────────────────────────────────
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REDIRECT_URI=http://localhost:8000/api/v1/outreach/oauth/callback

# ── Development Flags ─────────────────────────────────────────────────────────
# Set both to true during local development — no API keys needed.
# Flip to false when real keys are available and you want live data.
MOCK_AGENTS=true
USE_MOCK_DATA=true
