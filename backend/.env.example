# =============================================================================
# APEX .env.example — Last updated 2026-04-12
# =============================================================================
# API Stack Notes:
# - SEC EDGAR (data.sec.gov): NO KEY NEEDED — completely free public API
# - NewsData.io: free signup at newsdata.io — covers news + EU funding signals
# - PDL: free signup at peopledatalabs.com — replaces Proxycurl (shut down 2025)
# - Crunchbase: NOT USED — covered by SEC EDGAR Form D for US funding data
# - Proxycurl: NOT USED — shut down by LinkedIn lawsuit July 2025
# =============================================================================

# Backend environment variables for Apex Platform
# Copy this file to .env and fill in real values when available.
# During development, MOCK_AGENTS=true and USE_MOCK_DATA=true mean no real API calls are made.

# ── Database / Supabase ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/apex
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── AI / LLM ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# ── Signal Sources (all free tier — no paid plans needed for v1.0) ────────────
NEWSDATA_API_KEY=your_newsdata_key_here           # newsdata.io — free signup, 200 req/day
GNEWS_API_KEY=your_gnews_key_here                 # gnews.io — free signup, 100 req/day (backup)
# SEC EDGAR: NO KEY — data.sec.gov is fully public, zero cost, no auth required

# ── Contact Intelligence (replaces Proxycurl — shut down July 2025) ───────────
PDL_API_KEY=your_pdl_key_here                     # peopledatalabs.com — free signup, 1k credits/month
HUNTER_API_KEY=your_hunter_key_here               # hunter.io — free signup, 25 searches/month

# ── Adzuna Job Board (opportunity validation — free API) ─────────────────────
ADZUNA_APP_ID=your-adzuna-app-id      # developer.adzuna.com — free signup
ADZUNA_APP_KEY=your-adzuna-app-key
ADZUNA_COUNTRY=gb

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# ── Gmail OAuth ───────────────────────────────────────────────────────────────
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REDIRECT_URI=http://localhost:8000/api/v1/outreach/oauth/callback

# ── Development Flags ─────────────────────────────────────────────────────────
# Set both to true during local development — no API keys needed.
# Flip to false when real keys are available and you want live data.
MOCK_AGENTS=true
USE_MOCK_DATA=true
